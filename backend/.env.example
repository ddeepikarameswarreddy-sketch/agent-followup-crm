PORT=5000
FRONTEND_URL=http://localhost:5173

# PostgreSQL settings for local Windows pgAdmin setup
PGHOST=localhost
PGPORT=5432
PGDATABASE=agent_followup_crm
PGUSER=postgres
PGPASSWORD=your_postgres_password_here
PGSSL=false

# Optional single connection string instead of fields above
# DATABASE_URL=postgresql://postgres:your_postgres_password_here@localhost:5432/agent_followup_crm

# Deployment PostgreSQL option:
# Use cloud PostgreSQL DATABASE_URL and set PGSSL=true on Render/Railway/Neon/Supabase if required.
# DATABASE_URL=postgresql://user:password@host:5432/database
# PGSSL=true

# Email API / SMTP settings
# Keep EMAIL_ENABLED=false until your SMTP details are correct.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
EMAIL_FROM_NAME=Lohitha Dharma Projects CRM

# Optional future integration keys. Current AI layer is rule-based and API-ready.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# WHATSAPP_BUSINESS_TOKEN=
